<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suppressions PUBLIC
        "-//Puppy Crawl//DTD Suppressions 1.2//EN"
        "http://checkstyle.sourceforge.net/dtds/suppressions_1_2.dtd">
<suppressions>
    <!-- Temporarily suppress indentation checks for all Tests -->
    <!-- TODO: We should have these turned on. But, currently there's a known bug with indentation checks
         on JMockIt Expectations blocks and similar. See https://github.com/checkstyle/checkstyle/issues/3739 -->
    <suppress checks="Indentation" files="src[/\\]test[/\\]java"/>
    <suppress checks="Regexp" files="DSpaceHttpClientFactory\.java"/>

    <!-- Suppress checkstyle for Edinburgh DataShare custom code (pre-existing violations) -->
    <suppress files="[/\\]datashare[/\\]" checks=".*"/>
    <suppress files="uk[/\\]ac[/\\]ed[/\\]datashare[/\\]" checks=".*"/>

    <!-- Suppress checkstyle for upstream files modified by DataShare customisations -->
    <suppress files="ItemUpdate\.java" checks=".*"/>
    <suppress files="RequestItemEmailNotifier\.java" checks=".*"/>
    <suppress files="Constants\.java" checks=".*"/>
    <suppress files="DefaultEmbargoSetter\.java" checks=".*"/>
    <suppress files="EmbargoServiceImpl\.java" checks=".*"/>
    <suppress files="EmbargoService\.java" checks=".*"/>
    <suppress files="DataCiteConnector\.java" checks=".*"/>
    <suppress files="DOIOrganiser\.java" checks=".*"/>
    <suppress files="ITIrusExportUsageEventListener\.java" checks=".*"/>
</suppressions>
